  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6071cc",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment Doc",
      "scope": [
        "comment.block.documentation",
        "string.quoted.docstring"
      ],
      "settings": {
        "foreground": "#6f7bb0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#f92aad",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword Operator",
      "scope": [
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "keyword.operator.ternary",
        "keyword.operator.assignment"
      ],
      "settings": {
        "foreground": "#f92aad"
      }
    },
    {
      "name": "Storage Type",
      "scope": [
        "storage.type"
      ],
      "settings": {
        "foreground": "#b141f1"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#54e484"
      }
    },
    {
      "name": "String Escape",
      "scope": [
        "constant.character.escape",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#b4f9f8"
      }
    },
    {
      "name": "Number, Boolean, Null",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#ff9e64"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "variable.other.constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#e0b401"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#c0caf5"
      }
    },
    {
      "name": "Variable Language (this, self)",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#f92aad",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function"
      ],
      "settings": {
        "foreground": "#e0b401"
      }
    },
    {
      "name": "Function Parameter",
      "scope": [
        "variable.parameter.function",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#ff9e64",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Class, Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#58c7e0"
      }
    },
    {
      "name": "Inherited Class",
      "scope": [
        "entity.other.inherited-class"

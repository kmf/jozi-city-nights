        ext_indigo:    (red: 0.263, green: 0.235, blue: 0.820, alpha: 1.0),  // #433bd1
        ext_warm_grey: (red: 0.380, green: 0.447, blue: 0.686, alpha: 1.0),  // #6172af
        ext_yellow:    (red: 0.690, green: 0.502, blue: 0.000, alpha: 1.0),  // #b08000

        // neutrals — gray and neutral ramp
        gray_1:        (red: 0.835, green: 0.839, blue: 0.859, alpha: 1.0),  // #d5d6db  bg
        gray_2:        (red: 0.784, green: 0.788, blue: 0.820, alpha: 1.0),  // #c8c9d1  bg_soft
        gray_3:        (red: 0.749, green: 0.757, blue: 0.800, alpha: 1.0),  // #bfc1cc  bg_hi

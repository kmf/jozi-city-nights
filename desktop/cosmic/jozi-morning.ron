        accent_pink:   (red: 0.839, green: 0.098, blue: 0.478, alpha: 1.0),  // #d6197a
        accent_purple: (red: 0.475, green: 0.157, blue: 0.659, alpha: 1.0),  // #7928a8
        accent_red:    (red: 0.839, green: 0.098, blue: 0.478, alpha: 1.0),  // #d6197a
        accent_warm_grey: (red: 0.380, green: 0.447, blue: 0.686, alpha: 1.0), // #6172af
        accent_yellow: (red: 0.769, green: 0.565, blue: 0.000, alpha: 1.0),  // #c49000

        // ext slots — cosmic-specific bright accents
        ext_blue:      (red: 0.263, green: 0.235, blue: 0.820, alpha: 1.0),  // #433bd1
        ext_orange:    (red: 0.780, green: 0.298, blue: 0.020, alpha: 1.0),  // #c74c05
        ext_pink:      (red: 0.753, green: 0.063, blue: 0.420, alpha: 1.0),  // #c0106b

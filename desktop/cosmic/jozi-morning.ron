    warning: Some((red: 0.769, green: 0.565, blue: 0.000,)),
    destructive: Some((red: 0.753, green: 0.063, blue: 0.420,)),
    window_hint: Some((red: 0.263, green: 0.235, blue: 0.820,)),
    neutral_tint: Some((red: 0.380, green: 0.447, blue: 0.686,)),
    primary_container_bg: Some((red: 0.784, green: 0.788, blue: 0.820, alpha: 1.0,)),
    secondary_container_bg: Some((red: 0.749, green: 0.757, blue: 0.800, alpha: 1.0,)),

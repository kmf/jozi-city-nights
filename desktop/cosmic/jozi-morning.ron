// jozi-morning — a neon-lit colorscheme for COSMIC Desktop (light variant)
// https://github.com/kmf/jozi-city-nights

(
    palette: Light((
        name: "jozi-morning",

        // base accents
        blue:          (red: 0.310, green: 0.275, blue: 0.898, alpha: 1.0),  // #4f46e5
        red:           (red: 0.839, green: 0.098, blue: 0.478, alpha: 1.0),  // #d6197a
        green:         (red: 0.086, green: 0.525, blue: 0.290, alpha: 1.0),  // #16864a
        yellow:        (red: 0.769, green: 0.565, blue: 0.000, alpha: 1.0),  // #c49000

        // cosmic-specific brights — deeper/bolder for desktop UI
        bright_blue:   (red: 0.263, green: 0.235, blue: 0.820, alpha: 1.0),  // #433bd1
        bright_red:    (red: 0.753, green: 0.063, blue: 0.420, alpha: 1.0),  // #c0106b
        bright_green:  (red: 0.059, green: 0.459, blue: 0.247, alpha: 1.0),  // #0f753f
        bright_yellow: (red: 0.690, green: 0.502, blue: 0.000, alpha: 1.0),  // #b08000
        bright_orange: (red: 0.780, green: 0.298, blue: 0.020, alpha: 1.0),  // #c74c05

        // accent slots
        accent_blue:   (red: 0.310, green: 0.275, blue: 0.898, alpha: 1.0),  // #4f46e5
        accent_green:  (red: 0.086, green: 0.525, blue: 0.290, alpha: 1.0),  // #16864a

        neutral_5:     (red: 0.690, green: 0.702, blue: 0.745, alpha: 1.0),  // #b0b3be
        neutral_6:     (red: 0.749, green: 0.757, blue: 0.800, alpha: 1.0),  // #bfc1cc
        neutral_7:     (red: 0.784, green: 0.788, blue: 0.820, alpha: 1.0),  // #c8c9d1
        neutral_8:     (red: 0.835, green: 0.839, blue: 0.859, alpha: 1.0),  // #d5d6db  bg
